{
  "model_provider": "openai_compatible",
  "model_name": "gpt-5.4",
  "env_file": ".env",
  "api_key_priority": [
    "DEFAULT_LLM_API_KEY2"
  ],
  "base_url_env_name": "DEFAULT_LLM_BASE_URL2",
  "model_env_name": "DEFAULT_LLM_MODEL_NAME2",
  "openai_disable_thinking": true,
  "max_concurrency_per_key": 15,
  "llm_timeout_sec": 90,
  "llm_max_retries": 0,
  "llm_max_tokens": 1200,
  "max_ranked_files": 8,
  "max_patch_chars_per_file": 2500,
  "max_file_preview_chars": 2500,
  "llm_ranked_files": 4,
  "llm_patch_chars_per_file": 900,
  "llm_file_preview_chars": 900,
  "preview_extensions": [
    ".py",
    ".pyi",
    ".c",
    ".cc",
    ".cpp",
    ".cxx",
    ".h",
    ".hh",
    ".hpp",
    ".hxx",
    ".java",
    ".md",
    ".txt",
    ".rst",
    ".toml",
    ".yaml",
    ".yml",
    ".ini",
    ".json",
    ".cfg",
    ".cmake",
    ".gradle",
    ".properties",
    ".sh",
    ".bat",
    ".ps1",
    ".xml"
  ],
  "output_root": "data/auto_review"
}
